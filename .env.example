# Server Configuration
APP_SERVER__HOST=0.0.0.0
APP_SERVER__PORT=3000

# Invoice Ninja Configuration
APP_INVOICE_NINJA__BASE_URL=https://invoices.vunder.io/api/v1
APP_INVOICE_NINJA__API_TOKEN=your-invoice-ninja-api-token

# UOL Configuration
APP_UOL__BASE_URL=https://test.demo.uol.cz/api/v1
APP_UOL__USERNAME=your-uol-username
APP_UOL__PASSWORD=your-uol-password

# Logging
APP_LOGGING__LEVEL=info

# Email Notifications
APP_EMAIL__SMTP_HOST=smtp.example.com
APP_EMAIL__SMTP_PORT=587
APP_EMAIL__SMTP_USERNAME=user@example.com
APP_EMAIL__SMTP_PASSWORD=secret
APP_EMAIL__FROM="inuol-sync <noreply@example.com>"
APP_EMAIL__TO="Admin <admin@example.com>"
